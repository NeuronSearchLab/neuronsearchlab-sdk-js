{
  "name": "@neuronsearchlab/sdk",
  "version": "1.20.0",
  "description": "Official SDK for accessing NeuronSearchLab APIs",
  "type": "module",
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "node --test",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "author": "NeuronSearchLab",
  "license": "MIT",
  "homepage": "https://docs.neuronsearchlab.com",
  "bugs": {
    "url": "https://github.com/NeuronSearchLab/neuronsearchlab-sdk-js/issues"
  },
  "keywords": [
    "sdk",
    "neuronsearchlab",
    "recommendations",
    "ai",
    "personalization"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/NeuronSearchLab/neuronsearchlab-sdk-js.git"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/node": "^24.7.2",
    "tsup": "^8.3.5",
    "typescript": "^5.8.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "overrides": {
    "rollup": "^4.59.0",
    "fdir": {
      "picomatch": "^4.0.4"
    }
  }
}
